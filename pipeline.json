{
  "version": 1,
  "steps": [
    { "name": "ticket",         "number": 1,  "agent": "intake-agent,product-analyst", "reads": [],                                                     "writes": ["ticket.md"] },
    { "name": "analysis",       "number": 2,  "agent": "solution-architect",    "reads": ["ticket.md"],                                          "writes": ["analysis.md"] },
    { "name": "brainstorm",     "number": 3,  "agent": "superpowers:brainstorming", "reads": ["ticket.md", "analysis.md"],                       "writes": ["brainstorm.md"] },
    { "name": "plan",           "number": 4,  "agent": "planner",               "reads": ["ticket.md", "brainstorm.md", "analysis.md"],          "writes": ["plan.md"] },
    { "name": "plan-review",    "number": 5,  "agent": "solution-architect",    "reads": ["ticket.md", "analysis.md", "brainstorm.md", "plan.md"], "writes": ["plan.md"] },
    { "name": "estimation",     "number": 6,  "agent": "solution-architect",    "reads": ["ticket.md", "analysis.md", "brainstorm.md"],          "writes": ["overview.md"] },
    { "name": "implementation", "number": 7,  "agent": "developer",             "reads": ["brainstorm.md"],                                      "writes": ["implementation.md"] },
    { "name": "qa",             "number": 8,  "agent": "qa-engineer",           "reads": ["ticket.md", "implementation.md", "plan.md"],          "writes": ["qa.md"] },
    { "name": "review",         "number": 9,  "agent": "code-reviewer",         "reads": ["ticket.md", "brainstorm.md", "implementation.md", "qa.md"], "writes": ["review.md"] },
    { "name": "fix",            "number": 10, "agent": "developer",             "reads": ["implementation.md"],                                  "writes": ["implementation.md"] },
    { "name": "local-testing",  "number": 11, "agent": "developer",             "reads": ["implementation.md"],                                  "writes": ["local-testing.md"] },
    { "name": "pr",             "number": 12, "agent": "tech-writer",           "reads": ["overview.md", "review.md", "qa.md", "implementation.md"], "writes": ["overview.md"] },
    { "name": "ci",             "number": 13, "agent": "developer",             "reads": ["overview.md", "plan.md", "implementation.md"],        "writes": ["overview.md"] },
    { "name": "finish",         "number": 14, "agent": "n1:n1-finish",          "reads": ["overview.md"],                                        "writes": ["overview.md"] },
    { "name": "investigation-deliverable", "number": 15, "agent": "solution-architect", "reads": ["ticket.md", "analysis.md"], "writes": ["investigation.md"] }
  ],
  "gates": [
    { "name": "estimation",    "config_key": "estimation.enabled",     "default": false, "skips": ["estimation"] },
    { "name": "plan_review",   "config_key": "planReview.reviewPlan",  "default": true,  "skips": ["plan-review"] },
    { "name": "local_testing", "config_key": "localTesting.enabled",   "default": false, "skips": ["local-testing"] },
    { "name": "ci",            "config_key": "ciChecks.enabled",       "default": true,  "skips": ["ci"] },
    { "name": "finish",        "config_key": "finishWork.enabled",     "default": false, "skips": ["finish"] }
  ],
  "loops": [
    { "name": "qa_fix",            "trigger_step": "qa",            "trigger_outcome": "fail", "fix_step": "fix",            "retry_step": "qa",            "counter": "qa_fix_cycle",         "max_config_key": "qa.maxFixAttempts",           "max_default": 3 },
    { "name": "review_fix",        "trigger_step": "review",        "trigger_outcome": "fail", "fix_step": "fix",            "retry_step": "review",        "counter": "review_fix_cycle",     "max_config_key": "review.maxFixAttempts",       "max_default": 3 },
    { "name": "local_testing_fix", "trigger_step": "local-testing", "trigger_outcome": "fail", "fix_step": "local-test-fix", "retry_step": "local-testing", "counter": "local_test_fix_cycle", "max_config_key": "localTesting.maxFixAttempts", "max_default": 3 },
    { "name": "ci_fix",            "trigger_step": "ci",            "trigger_outcome": "fail", "fix_step": null,             "retry_step": "ci",            "counter": "ci_fix_cycle",         "max_config_key": "ciChecks.maxFixAttempts",     "max_default": 3 }
  ],
  "routing": [
    { "step": "ticket",         "outcome": "pass",       "next": "analysis",       "when": null },
    { "step": "analysis",       "outcome": "pass",       "next": "brainstorm",     "when": null },
    { "step": "brainstorm",     "outcome": "pass",       "next": "investigation-deliverable", "when": {"investigation": true} },
    { "step": "brainstorm",     "outcome": "pass",       "next": "plan",           "when": "plan" },
    { "step": "brainstorm",     "outcome": "pass",       "next": "implementation", "when": "direct" },
    { "step": "plan",           "outcome": "pass",       "next": "plan-review",    "when": { "config": "planReview.reviewPlan", "eq": true } },
    { "step": "plan",           "outcome": "pass",       "next": "estimation",     "when": { "all": [ { "config": "planReview.reviewPlan", "eq": false }, { "config": "estimation.enabled", "eq": true } ] } },
    { "step": "plan",           "outcome": "pass",       "next": "implementation", "when": { "all": [ { "config": "planReview.reviewPlan", "eq": false }, { "config": "estimation.enabled", "neq": true } ] } },
    { "step": "plan-review",    "outcome": "pass",       "next": "estimation",     "when": { "config": "estimation.enabled", "eq": true } },
    { "step": "plan-review",    "outcome": "pass",       "next": "implementation", "when": { "config": "estimation.enabled", "neq": true } },
    { "step": "plan-review",    "outcome": "skip",       "next": "estimation",     "when": { "config": "estimation.enabled", "eq": true } },
    { "step": "plan-review",    "outcome": "skip",       "next": "implementation", "when": { "config": "estimation.enabled", "neq": true } },
    { "step": "estimation",     "outcome": "pass",       "next": "implementation", "when": null },
    { "step": "estimation",     "outcome": "skip",       "next": "implementation", "when": null },
    { "step": "implementation", "outcome": "pass",       "next": "qa",             "when": null },
    { "step": "qa",             "outcome": "pass",       "next": "review",         "when": null },
    { "step": "qa",             "outcome": "fail",       "next": "fix",            "when": { "counter": "qa_fix_cycle", "lt": "qa.maxFixAttempts" } },
    { "step": "qa",             "outcome": "escalation", "next": null,             "when": { "counter": "qa_fix_cycle", "gte": "qa.maxFixAttempts" } },
    { "step": "review",         "outcome": "pass",       "next": "local-testing",  "when": { "config": "localTesting.enabled", "eq": true } },
    { "step": "review",         "outcome": "pass",       "next": "pr",             "when": { "config": "localTesting.enabled", "neq": true } },
    { "step": "review",         "outcome": "fail",       "next": "fix",            "when": { "counter": "review_fix_cycle", "lt": "review.maxFixAttempts" } },
    { "step": "review",         "outcome": "escalation", "next": null,             "when": { "counter": "review_fix_cycle", "gte": "review.maxFixAttempts" } },
    { "step": "fix",            "outcome": "pass",       "next": "qa",             "when": { "overview_step": "qa" } },
    { "step": "fix",            "outcome": "pass",       "next": "review",         "when": { "overview_step": "review" } },
    { "step": "local-testing",  "outcome": "pass",       "next": "pr",             "when": null },
    { "step": "local-testing",  "outcome": "skip",       "next": "pr",             "when": null },
    { "step": "local-testing",  "outcome": "fail",       "next": null,             "when": null },
    { "step": "local-testing",  "outcome": "escalation", "next": null,             "when": null },
    { "step": "pr",             "outcome": "pass",       "next": "ci",             "when": { "all": [ { "config": "ciChecks.enabled", "eq": true }, { "config": "git.prMode", "neq": "skip" } ] } },
    { "step": "pr",             "outcome": "pass",       "next": "finish",         "when": { "all": [ { "any": [ { "config": "ciChecks.enabled", "neq": true }, { "config": "git.prMode", "eq": "skip" } ] }, { "config": "finishWork.enabled", "eq": true } ] } },
    { "step": "pr",             "outcome": "pass",       "next": null,             "when": { "any": [ { "config": "ciChecks.enabled", "neq": true }, { "config": "git.prMode", "eq": "skip" } ] } },
    { "step": "ci",             "outcome": "pass",       "next": "finish",         "when": { "config": "finishWork.enabled", "eq": true } },
    { "step": "ci",             "outcome": "pass",       "next": null,             "when": null },
    { "step": "ci",             "outcome": "skip",       "next": "finish",         "when": { "config": "finishWork.enabled", "eq": true } },
    { "step": "ci",             "outcome": "skip",       "next": null,             "when": null },
    { "step": "ci",             "outcome": "fail",       "next": null,             "when": null },
    { "step": "investigation-deliverable", "outcome": "pass", "next": null, "when": null },
    { "step": "finish",         "outcome": "pass",       "next": null,             "when": null },
    { "step": "finish",         "outcome": "skip",       "next": null,             "when": null },
    { "step": "finish",         "outcome": "fail",       "next": null,             "when": null },
    { "step": "finish",         "outcome": "escalation", "next": null,             "when": null }
  ]
}
